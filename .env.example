# ----------------------------------------------------------------------------
# Nopal AI Docs — environment variables
# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored and never committed.
# ----------------------------------------------------------------------------

# OpenRouter API key — used ONLY on the server (never exposed to the browser).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# The model used for AI features (a free, capable model by default).
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Optional: shown to OpenRouter for app attribution / rankings.
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Nopal AI Docs
